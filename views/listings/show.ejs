<% layout("layouts/boilerplate") %>

<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3><%= listing.title %></h3>
  </div>

  <div class="card col-6 offset-2 listing-card">
    <img
      src="<%= listing.image %>"
      class="card-img-top show-img"
      alt="listing_image"
    />
    <div class="card-body">
      <p class="card-text">
        <br />
        <%= listing.description %>
        <br />
        &#8377;<%= listing.price.toLocaleString("en-IN") %>
        <br />
        <%= listing.location %>
        <br />
        <%= listing.country %>
      </p>
    </div>
  </div>

  <div class="col-6 offset-2 mb-3">
    <div class="d-flex gap-3">
      <a
        href="/listings/<%= listing._id %>/edit"
        class="btn btn-danger edit-btn"
        >Edit</a
      >

      <form method="post" action="/listings/<%= listing._id %>">
        <button class="btn btn-dark">Delete</button>
      </form>
    </div>
  </div>
  <hr />
  <div class="col-8 offset-3 mb-3">
    <h4>Leave a Review</h4>
    <form
      action="/listings/<%= listing._id%>/reviews"
      method="post"
      novalidate
      class="needs-validation"
    >
      <div class="mb-3 mt-3">
        <label for="rating" class="form-label">Rating</label>
        <input
          type="range"
          min="1"
          max="5"
          id="rating"
          name="review[rating]"
          class="form-range"
        />
      </div>
      <div class="mb-3 mt-3">
        <label for="comment" class="form-label">Comments</label>
        <textarea
          name="review[comment]"
          id="comment"
          rows="10"
          cols="30"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">
          Please submit some comment for review
        </div>
      </div>
      <button class="btn btn-outline-dark">Submit</button>
    </form>
    <h4>All Reviews</h4>
    <div class="row">
    <% for(let review of listing.reviews){ %>
    <div class="card col-5 ms-3 mb-3">
      <div class="card-body">
        <h5 class="card-title">Jane</h5>
        <p class="card-text">
          <%= review.comment %>
        </p>
        <p class="card-text">
          <%= review.rating %>stars
        </p>
        <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=Delete" class="mb-3" method="post">
          <button class="btn btn-small btn-outline-dark">Delete</button>
        </form>
      </div>
    </div>
    <%} %>
    </div>
  </div>
</div>
